# colorscheme
include kanagawa_theme

# options
set selection-clipboard false
set dbus-raise-window false
set guioptions none
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 5
set font "JetBrains Mono 11"

# reduce flickering
set render-loading-bg "#ffffff"
set render-loading    false # don't display Loading...

# mappings
map u scroll half-up
map d scroll half-down
map D toggle_page_mode 2
map i recolor
map R reload
map p print
map <C-h> nohlsearch
