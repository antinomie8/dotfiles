# highlighting theme
--theme="Kanagawa"

# force colorizing the output
--color=always

# change the tab width
--tabs 2

# disable automatic paging
--paging=never

# enable this to use italic text on the terminal.
--italic-text=always

# syntax mappings: map a certain filename pattern to a language.
--map-syntax "*.conf:ini"
--map-syntax "*justfile:Makefile"
